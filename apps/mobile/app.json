{
  "expo": {
    "name": "Nicht Rauchen",
    "slug": "nicht-rauchen-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "scheme": "nichtrauchen",
    "description": "Die ultimative App zum Rauchstopp! Verfolge deine Fortschritte, erhalte tägliche Erinnerungen und erreiche deine Ziele mit unserem intelligenten Tracking-System.",
    "platforms": [
      "ios",
      "android"
    ],
    "githubUrl": "https://github.com/iborekt/nicht-rauchen-app",
    "primaryColor": "#3BFF91",
    "backgroundColor": "#081023",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#081023"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nichtrauchen.app",
      "buildNumber": "1",
      "appStoreUrl": "https://apps.apple.com/app/nicht-rauchen/id1234567890",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "background-processing",
          "background-fetch"
        ],
        "NSUserNotificationsUsageDescription": "Diese App sendet tägliche Erinnerungen um 18:00 Uhr, um dich an deinen Check-in zu erinnern (nur wenn du noch nicht eingecheckt hast).",
        "NSCameraUsageDescription": "Erlaubt das Aufnehmen von Fotos für deine Fortschrittsdokumentation.",
        "NSPhotoLibraryUsageDescription": "Erlaubt den Zugriff auf deine Fotos für die Fortschrittsdokumentation.",
        "NSMicrophoneUsageDescription": "Erlaubt das Aufnehmen von Audio-Memos für deine Motivation.",
        "NSLocationWhenInUseUsageDescription": "Erlaubt die Standortbestimmung für personalisierte Inhalte.",
        "CFBundleDisplayName": "Nicht Rauchen",
        "CFBundleName": "Nicht Rauchen",
        "CFBundleShortVersionString": "1.0.0",
        "CFBundleVersion": "1",
        "LSRequiresIPhoneOS": true,
        "UILaunchStoryboardName": "SplashScreen",
        "UIRequiredDeviceCapabilities": [
          "armv7"
        ],
        "UIStatusBarStyle": "UIStatusBarStyleDefault",
        "UIViewControllerBasedStatusBarAppearance": false,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      },
      "associatedDomains": [
        "applinks:nichtrauchen.app"
      ],
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "package": "com.nichtrauchen.app",
      "versionCode": 1,
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.nichtrauchen.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nichtrauchen.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "sitemap": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-video",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3BFF91",
          "defaultChannel": "default"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false,
        "sitemap": false
      },
      "eas": {
        "projectId": "d1387ef6-502c-4f95-b3c8-4532c26bdd96"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "iborekt"
  }
}
