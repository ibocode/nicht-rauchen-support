{
	"cli": {
		"version": ">= 15.0.15",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal",
			"ios": {
				"simulator": true
			}
		},
		"production": {
			"autoIncrement": true,
			"ios": {
				"buildConfiguration": "Release",
				"env": {
					"RCT_NEW_ARCH_ENABLED": "0",
					"USE_FRAMEWORKS": "static"
				}
			},
			"android": {
				"buildType": "apk"
			}
		}
	},
	"submit": {
		"production": {
			"ios": {
				"appleId": "iborekt@example.com",
				"ascAppId": "1234567890",
				"appleTeamId": "ABCD123456"
			},
			"android": {
				"serviceAccountKeyPath": "./path/to/api-key.json",
				"track": "production"
			}
		}
	}
}
